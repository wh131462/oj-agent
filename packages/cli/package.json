{
  "name": "@oj-agent/cli",
  "version": "0.0.1",
  "description": "OJ-Agent CLI (oja). Multi-OJ workflow: login / list / pull / test / submit.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wh131462/oj-agent.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "oj",
    "cli",
    "leetcode",
    "codeforces",
    "competitive-programming"
  ],
  "type": "module",
  "bin": {
    "oja": "./dist/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "test": "node --test --import tsx $(find test -name '*.test.ts' | sort)"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@oj-agent/core": "workspace:*"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0",
    "playwright-core": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}