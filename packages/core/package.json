{
  "name": "@oj-agent/core",
  "version": "0.0.1",
  "description": "OJ-Agent core engine. Platform-agnostic. Used by both CLI and VSCode extension.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wh131462/oj-agent.git",
    "directory": "packages/core"
  },
  "keywords": [
    "oj",
    "leetcode",
    "codeforces",
    "hdoj",
    "luogu",
    "poj",
    "online-judge"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "test": "node --test --import tsx \"test/**/*.test.ts\""
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "chokidar": "^3.6.0",
    "iconv-lite": "^0.6.3",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}